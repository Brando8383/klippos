[Unit]
Description=KlippOS First Boot Setup
After=network-online.target
Wants=network-online.target
ConditionPathExists=!/etc/klippos/.setup_complete

[Service]
Type=oneshot
ExecStart=/usr/local/bin/klippos-setup.sh
RemainAfterExit=yes
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
